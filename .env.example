# Copy to .env.local and fill in values. Never commit real secrets.

# Sanity (public in browser — project ID is not a secret)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Resend — server only
RESEND_API_KEY=

# Contact form — server only
CONTACT_EMAIL=

# Optional: verified sender, e.g. "Portfolio <contact@yourdomain.com>"
# Falls back to Resend onboarding domain if unset (dev only).
# CONTACT_FROM=
